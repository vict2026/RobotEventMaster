# ── 腾讯会议企业版 API ──────────────────────────────────────────────────────
TENCENT_MEETING_APP_ID=
TENCENT_MEETING_SDK_ID=
TENCENT_MEETING_SECRET_ID=
TENCENT_MEETING_SECRET_KEY=
TENCENT_MEETING_OPERATOR_ID=
TENCENT_MEETING_OPERATOR_ID_TYPE=1
TENCENT_MEETING_BASE_URL=https://api.meeting.qq.com

# ── 数据库（默认 SQLite，生产环境建议使用 PostgreSQL） ─────────────────────────
# DATABASE_URL=sqlite:///data/robot_event.db
DATABASE_URL=postgresql://robot:robot123@db:5432/robot_event

# ── Edge-TTS ──────────────────────────────────────────────────────────────────
TTS_VOICE=zh-CN-XiaoxiaoNeural
TTS_RATE=+0%
TTS_VOLUME=+0%

# ── YOLOv11 ───────────────────────────────────────────────────────────────────
YOLO_MODEL_PATH=models/yolov11n.pt
YOLO_CONFIDENCE=0.5
YOLO_IOU=0.45
FRAME_SAMPLE_INTERVAL=5

# ── 时区 ──────────────────────────────────────────────────────────────────────
TZ=Asia/Shanghai
